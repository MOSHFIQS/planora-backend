model Banner {
    id String @id @default(uuid())

    title       String
    description String?

    image       String
    redirectUrl String?

    position      BannerPosition
    positionOrder Int

    buttonText String?
    altText    String?

    isActive Boolean @default(true)

    isDeleted Boolean   @default(false)
    deletedAt DateTime?

    createdAt DateTime @default(now())
    updatedAt DateTime @updatedAt

    @@index([position])
    @@index([isActive])
    @@map("banner")
}