<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0"/>
  <title>Invoice</title>

  <style>
    body {
      margin: 0;
      padding: 0;
      background-color: #f5f7fb;
      font-family: -apple-system, BlinkMacSystemFont, "Segoe UI", Roboto, Arial, sans-serif;
      color: #111827;
    }

    .wrapper {
      max-width: 680px;
      margin: 40px auto;
      background: #ffffff;
      border-radius: 10px;
      overflow: hidden;
      box-shadow: 0 10px 30px rgba(0,0,0,0.06);
    }

    .header {
      background: #111827;
      color: #ffffff;
      padding: 30px;
      text-align: center;
    }

    .header h1 {
      margin: 0;
      font-size: 22px;
      letter-spacing: 1px;
    }

    .header p {
      margin-top: 6px;
      font-size: 13px;
      color: #9ca3af;
    }

    .content {
      padding: 30px;
    }

    .greeting {
      font-size: 16px;
      margin-bottom: 10px;
    }

    .muted {
      color: #6b7280;
      font-size: 14px;
      margin-bottom: 25px;
    }

    .card {
      border: 1px solid #e5e7eb;
      border-radius: 8px;
      padding: 18px;
      margin-bottom: 20px;
      background: #fff;
    }

    .row {
      display: flex;
      justify-content: space-between;
      padding: 8px 0;
      font-size: 14px;
      border-bottom: 1px solid #f3f4f6;
    }

    .row:last-child {
      border-bottom: none;
    }

    .label {
      color: #6b7280;
    }

    .value {
      font-weight: 500;
      color: #111827;
      text-align: right;
    }

    .section-title {
      font-size: 13px;
      font-weight: 600;
      color: #374151;
      margin: 20px 0 10px;
      text-transform: uppercase;
      letter-spacing: 0.5px;
    }

    .total-box {
      background: #111827;
      color: #ffffff;
      padding: 20px;
      border-radius: 8px;
      text-align: center;
      margin-top: 25px;
    }

    .total-box h2 {
      margin: 5px 0 0;
      font-size: 24px;
    }

    .badge {
      display: inline-block;
      margin-top: 8px;
      background: #22c55e;
      color: #fff;
      padding: 5px 12px;
      border-radius: 20px;
      font-size: 12px;
    }

    .btn {
      display: inline-block;
      margin-top: 20px;
      background: #111827;
      color: #ffffff !important;
      padding: 10px 18px;
      border-radius: 6px;
      text-decoration: none;
      font-size: 14px;
    }

    .footer {
      text-align: center;
      padding: 20px;
      font-size: 12px;
      color: #9ca3af;
      background: #f9fafb;
    }

    @media (max-width: 600px) {
      .row {
        flex-direction: column;
        align-items: flex-start;
      }

      .value {
        text-align: left;
        margin-top: 4px;
      }
    }
  </style>
</head>

<body>
  <div class="wrapper">

    <!-- Header -->
    <div class="header">
      <h1>Invoice Receipt</h1>
      <p>Event Management System</p>
    </div>

    <!-- Content -->
    <div class="content">

      <div class="greeting">
        Hello <strong><%= userName %></strong>,
      </div>

      <div class="muted">
        Thank you for your payment. Below is your official invoice.
      </div>

      <!-- Invoice Info -->
      <div class="section-title">Invoice Details</div>
      <div class="card">
        <div class="row">
          <span class="label">Invoice ID</span>
          <span class="value"><%= invoiceId %></span>
        </div>
        <div class="row">
          <span class="label">Transaction ID</span>
          <span class="value"><%= transactionId %></span>
        </div>
        <div class="row">
          <span class="label">Payment Date</span>
          <span class="value"><%= paymentDate %></span>
        </div>
      </div>

      <!-- Event Info -->
      <div class="section-title">Event Details</div>
      <div class="card">
        <div class="row">
          <span class="label">Event Name</span>
          <span class="value"><%= eventName %></span>
        </div>
        <div class="row">
          <span class="label">Event Date</span>
          <span class="value"><%= eventDate %></span>
        </div>
      </div>

      <!-- Payment Summary -->
      <div class="section-title">Payment Summary</div>
      <div class="card">
        <div class="row">
          <span class="label">Amount</span>
          <span class="value"><%= amount.toFixed(2) %> BDT</span>
        </div>
      </div>

      <!-- Total -->
      <div class="total-box">
        <p style="margin:0; font-size:13px; color:#9ca3af;">Total Paid</p>
        <h2><%= amount.toFixed(2) %> BDT</h2>
        <div class="badge">PAID</div>
      </div>

      <!-- Download Button -->
      <% if (invoiceUrl) { %>
        <div style="text-align:center;">
          <a href="<%= invoiceUrl %>" class="btn">Download PDF Invoice</a>
        </div>
      <% } %>

      <p style="margin-top:25px; font-size:13px; color:#6b7280;">
        This invoice is automatically generated. Please keep it for your records.
      </p>

    </div>

    <!-- Footer -->
    <div class="footer">
      <p><strong>PLANORA</strong></p>
      <p>© 2026 All rights reserved</p>
    </div>

  </div>
</body>
</html>